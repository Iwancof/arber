        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 101,
      "type": "row",
      "title": "Ingest Timeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Documents Ingested Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  date_trunc('hour', ingested_at) as time,\n  count(*) as documents\nFROM content.raw_document\nGROUP BY 1\nORDER BY 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 102,
      "type": "row",
      "title": "Source Details",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "table",
      "title": "Source Registry",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  sr.source_code,\n  sr.display_name,\n  sr.source_type,\n  sr.trust_tier,\n  sr.latency_class,\n  sr.status,\n  (SELECT count(*) FROM content.raw_document rd WHERE rd.source_id = sr.source_id) as doc_count\nFROM sources.source_registry sr\nORDER BY sr.source_code",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "active": { "color": "green", "text": "active" } } },
                  { "type": "value", "options": { "inactive": { "color": "yellow", "text": "inactive" } } },
                  { "type": "value", "options": { "disabled": { "color": "red", "text": "disabled" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "trust_tier" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "tier_1": { "color": "green", "text": "tier_1" } } },
                  { "type": "value", "options": { "tier_2": { "color": "yellow", "text": "tier_2" } } },
                  { "type": "value", "options": { "tier_3": { "color": "orange", "text": "tier_3" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "doc_count" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "basic"
                }
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 1000
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 10 },
                    { "color": "green", "value": 100 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        },
        "sortBy": [
          { "displayName": "source_code", "desc": false }
        ]
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 103,
      "type": "row",
      "title": "Document Details",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "table",
      "title": "Recent Documents",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  rd.headline,\n  sr.source_code,\n  rd.source_tier,\n  rd.language_code,\n  rd.published_at,\n  rd.ingested_at,\n  rd.content_hash\nFROM content.raw_document rd\nJOIN sources.source_registry sr ON sr.source_id = rd.source_id\nORDER BY rd.ingested_at DESC\nLIMIT 30",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "content_hash" },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "headline" },
            "properties": [
              {
                "id": "custom.width",
                "value": 350
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        }
      },
      "pluginVersion": "11.0.0"
    }
  ],
