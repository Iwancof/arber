      "type": "table",
      "title": "Forecast Analysis",
      "description": "Full forecast detail with confidence changes, hypotheses, horizon metrics, and decisions.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  i.symbol as \"Symbol\",\n  f.forecast_json->>'direction_hint' as \"Direction\",\n  (f.forecast_json->>'confidence_before')::text as \"Conf Before\",\n  (f.forecast_json->>'confidence_after')::text as \"Conf After\",\n  f.forecast_json->>'selected_hypothesis' as \"Hypothesis\",\n  fh1.p_outperform_benchmark as \"1d P(Out)\",\n  fh1.ret_q50 as \"1d Q50\",\n  fh5.p_outperform_benchmark as \"5d P(Out)\",\n  fh5.ret_q50 as \"5d Q50\",\n  d.action as \"Action\",\n  d.score as \"Score\"\nFROM forecasting.forecast_ledger f\nLEFT JOIN core.instrument i ON i.instrument_id = f.instrument_id\nLEFT JOIN forecasting.forecast_horizon fh1 ON fh1.forecast_id = f.forecast_id AND fh1.horizon_code = '1d'\nLEFT JOIN forecasting.forecast_horizon fh5 ON fh5.forecast_id = f.forecast_id AND fh5.horizon_code = '5d'\nLEFT JOIN forecasting.decision_ledger d ON d.forecast_id = f.forecast_id\nORDER BY f.forecasted_at DESC\nLIMIT 10",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
