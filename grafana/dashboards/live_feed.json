    {
      "id": 1,
      "type": "timeseries",
      "title": "Event & Decision Timeline",
      "description": "Materiality as bars, direction signal as line. Tracks event flow over time.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  el.created_at as time,\n  el.materiality as \"Materiality\",\n  CASE el.direction_hint\n    WHEN 'positive' THEN 0.8\n    WHEN 'negative' THEN -0.8\n    WHEN 'neutral' THEN 0\n    ELSE 0.2\n  END as \"Direction Signal\"\nFROM content.event_ledger el\nORDER BY el.created_at",
          "format": "time_series",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": true,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 6,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Materiality" },
            "properties": [
              { "id": "custom.drawStyle", "value": "bars" },
              { "id": "custom.fillOpacity", "value": 60 },
              { "id": "custom.gradientMode", "value": "scheme" },
              { "id": "color", "value": { "mode": "continuous-blues" } },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "custom.barAlignment", "value": 0 },
              { "id": "custom.axisSoftMin", "value": 0 },
              { "id": "custom.axisSoftMax", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Direction Signal" },
            "properties": [
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 15 },
              { "id": "custom.gradientMode", "value": "scheme" },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } },
              { "id": "custom.lineInterpolation", "value": "smooth" },
              { "id": "custom.pointSize", "value": 8 },
              { "id": "custom.showPoints", "value": "always" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showValues": "last",
          "calcs": ["lastNotNull", "mean"]
        }
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 200,
      "type": "row",
