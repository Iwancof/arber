    {
      "id": 8,
      "type": "stat",
      "title": "Signal vs Noise",
      "description": "Documents that produced events (Signal) vs those that did not (Noise) in the last 24 hours.",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 36 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  count(*) FILTER (WHERE el.event_id IS NOT NULL) as \"Signal\",\n  count(*) FILTER (WHERE el.event_id IS NULL) as \"Noise/Unmatched\"\nFROM content.raw_document rd\nLEFT JOIN content.event_ledger el ON el.raw_document_id = rd.raw_document_id\nWHERE rd.ingested_at > now() - interval '24 hours'",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "0", "color": "text" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null }
            ]
          },
          "unit": "short"
        },
