    {
      "id": 2,
      "type": "gauge",
      "title": "Confidence Gauge",
      "description": "Average forecast confidence in the last 6 hours.",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  avg((f.forecast_json->>'confidence_after')::numeric) as \"Avg Confidence\"\nFROM forecasting.forecast_ledger f\nWHERE f.forecasted_at > now() - interval '6 hours'",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "min": 0.4,
          "max": 1.0,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#F2495C", "value": 0.5 },
              { "color": "#FF9830", "value": 0.58 },
              { "color": "#73BF69", "value": 0.65 }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "No data", "color": "text" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "sizing": "auto",
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "pluginVersion": "11.0.0"
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Outperform Probability",
      "description": "1-day P(Outperform Benchmark) by symbol, last 6 hours.",
      "gridPos": { "h": 7, "w": 9, "x": 6, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  i.symbol,\n  fh.p_outperform_benchmark as \"P(Outperform)\"\nFROM forecasting.forecast_horizon fh\nJOIN forecasting.forecast_ledger f ON f.forecast_id = fh.forecast_id\nLEFT JOIN core.instrument i ON i.instrument_id = f.instrument_id\nWHERE fh.horizon_code = '1d'\n  AND f.forecasted_at > now() - interval '6 hours'\nORDER BY fh.p_outperform_benchmark DESC",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#F2495C", "value": 0.45 },
              { "color": "#FADE2A", "value": 0.52 },
              { "color": "#73BF69", "value": 0.58 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "fields": "/P\\(Outperform\\)/"
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "sizing": "auto",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "text": {}
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "symbol": "Symbol"
            },
            "indexByName": {
              "symbol": 0,
              "P(Outperform)": 1
            }
          }
        }
      ],
      "pluginVersion": "11.0.0"
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Decision Score Distribution",
      "description": "Decision scores by symbol, colored by action. Last 6 hours.",
      "gridPos": { "h": 7, "w": 9, "x": 15, "y": 10 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  i.symbol,\n  d.score as \"Score\",\n  d.action\nFROM forecasting.decision_ledger d\nJOIN forecasting.forecast_ledger f ON f.forecast_id = d.forecast_id\nLEFT JOIN core.instrument i ON i.instrument_id = f.instrument_id\nWHERE d.decided_at > now() - interval '6 hours'\nORDER BY d.score DESC",
          "format": "table",
          "editorMode": "code"
        }
