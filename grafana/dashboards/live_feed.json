      "type": "table",
      "title": "Recent News Headlines",
      "description": "Latest ingested documents with event extraction results.",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 18 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
