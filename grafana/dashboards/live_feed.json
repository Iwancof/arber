      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  rd.ingested_at as \"Time\",\n  rd.headline as \"Headline\",\n  el.event_type as \"Event\",\n  el.direction_hint as \"Direction\",\n  el.materiality as \"Mat.\",\n  i.symbol as \"Symbol\",\n  CASE\n    WHEN el.event_type LIKE 'corp_%' THEN '🏢'\n    WHEN el.event_type LIKE 'macro_%' THEN '🌍'\n    WHEN el.event_type LIKE 'reg_%' THEN '⚖️'\n    WHEN el.event_type LIKE 'market_%' THEN '📊'\n    ELSE '📄'\n  END as \"Type\"\nFROM content.raw_document rd\nLEFT JOIN content.event_ledger el ON el.raw_document_id = rd.raw_document_id\nLEFT JOIN core.instrument i ON i.instrument_id = el.issuer_instrument_id\nORDER BY rd.ingested_at DESC\nLIMIT 15",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
