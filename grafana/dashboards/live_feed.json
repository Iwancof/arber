      "type": "timeseries",
      "title": "Pipeline Throughput",
      "description": "Hourly document ingestion and event extraction throughput.",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 36 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  date_trunc('hour', rd.ingested_at) as time,\n  count(*) as \"Documents\",\n  count(DISTINCT el.event_id) as \"Events\"\nFROM content.raw_document rd\nLEFT JOIN content.event_ledger el ON el.raw_document_id = rd.raw_document_id\nGROUP BY 1\nORDER BY 1",
