    {
      "id": 103,
      "type": "row",
      "title": "Response History",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent Responses",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  ir.response_channel,\n  ir.response_status,\n  ir.schema_valid,\n  ir.submitted_at,\n  it.question_title,\n  ic.primary_symbol\nFROM human_ops.inquiry_response ir\nJOIN human_ops.inquiry_task it ON it.inquiry_task_id = ir.inquiry_task_id\nJOIN human_ops.inquiry_case ic ON ic.inquiry_case_id = it.inquiry_case_id\nORDER BY ir.submitted_at DESC\nLIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "response_status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "accepted": { "color": "green", "text": "accepted" } } },
                  { "type": "value", "options": { "rejected": { "color": "red", "text": "rejected" } } },
                  { "type": "value", "options": { "pending": { "color": "yellow", "text": "pending" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "schema_valid" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "true": { "color": "green", "text": "valid" } } },
                  { "type": "value", "options": { "false": { "color": "red", "text": "invalid" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        }
      },
      "pluginVersion": "11.0.0"
    }
