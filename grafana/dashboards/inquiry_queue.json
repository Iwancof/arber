      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "table",
      "title": "Active Inquiries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  ic.title,\n  ic.inquiry_kind,\n  ic.primary_symbol,\n  ic.urgency_class,\n  it.task_status,\n  it.priority_score,\n  it.sla_class,\n  it.deadline_at,\n  it.question_title,\n  CASE\n    WHEN it.deadline_at < now() THEN 'OVERDUE'\n    WHEN it.deadline_at < now() + interval '15 minutes' THEN 'DUE SOON'\n    ELSE 'OK'\n  END as time_status\nFROM human_ops.inquiry_task it\nJOIN human_ops.inquiry_case ic ON ic.inquiry_case_id = it.inquiry_case_id\nWHERE it.task_status IN ('visible','claimed','awaiting_response','submitted')\nORDER BY it.priority_score DESC, it.deadline_at ASC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "time_status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "OVERDUE": { "color": "red", "text": "OVERDUE" } } },
                  { "type": "value", "options": { "DUE SOON": { "color": "orange", "text": "DUE SOON" } } },
                  { "type": "value", "options": { "OK": { "color": "green", "text": "OK" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "urgency_class" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "color": "red", "text": "critical" } } },
                  { "type": "value", "options": { "high": { "color": "orange", "text": "high" } } },
                  { "type": "value", "options": { "normal": { "color": "green", "text": "normal" } } },
                  { "type": "value", "options": { "low": { "color": "blue", "text": "low" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "priority_score" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "basic"
                }
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 100
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        },
        "sortBy": [
          { "displayName": "priority_score", "desc": true }
        ]
      },
      "pluginVersion": "11.0.0"
    },
