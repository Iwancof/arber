    {
      "id": 1,
      "type": "table",
      "title": "Full Dossier Table",
      "description": "Complete decision chain: headline, LLM analysis, action, and score for each decision",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  rd.headline as \"Headline\",\n  e.event_type as \"Event Type\",\n  e.direction_hint as \"Direction\",\n  e.materiality as \"Materiality\",\n  i.symbol as \"Symbol\",\n  f.model_family as \"Model\",\n  CASE\n    WHEN f.forecast_json->>'reasoning' IS NOT NULL\n    THEN substring(f.forecast_json->>'reasoning' from 1 for 300)\n    WHEN f.forecast_json->>'rationale' IS NOT NULL\n    THEN substring(f.forecast_json->>'rationale' from 1 for 300)\n    ELSE substring(f.forecast_json::text from 1 for 300)\n  END as \"LLM Analysis\",\n  d.action as \"Action\",\n  d.score as \"Score\",\n  d.decision_status as \"Status\",\n  d.decided_at as \"Time\"\nFROM forecasting.decision_ledger d\nJOIN forecasting.forecast_ledger f ON f.forecast_id = d.forecast_id\nLEFT JOIN content.event_ledger e ON e.event_id = f.event_id\nLEFT JOIN core.instrument i ON i.instrument_id = f.instrument_id\nLEFT JOIN content.raw_document rd ON rd.raw_document_id = e.raw_document_id\nORDER BY d.decided_at DESC\nLIMIT 20",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "filterable": true
          },
