    {
      "id": 4,
      "type": "table",
      "title": "Event Stream",
      "description": "Latest 50 events with instrument and document details",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  el.event_type,\n  el.direction_hint,\n  el.materiality,\n  el.novelty,\n  el.verification_status,\n  i.symbol,\n  rd.headline,\n  el.created_at\nFROM content.event_ledger el\nLEFT JOIN core.instrument i ON i.instrument_id = el.issuer_instrument_id\nLEFT JOIN content.raw_document rd ON rd.raw_document_id = el.raw_document_id\nORDER BY el.created_at DESC\nLIMIT 50",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "materiality" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "yellow", "value": 0.3 },
                    { "color": "orange", "value": 0.6 },
                    { "color": "red", "value": 0.8 }
                  ]
                }
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "novelty" },
            "properties": [
              {
                "id": "decimals",
                "value": 3
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "direction_hint" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "bullish": { "color": "green", "text": "Bullish" } } },
                  { "type": "value", "options": { "bearish": { "color": "red", "text": "Bearish" } } },
                  { "type": "value", "options": { "neutral": { "color": "blue", "text": "Neutral" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "verification_status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "extracted": { "color": "yellow", "text": "Extracted" } } },
                  { "type": "value", "options": { "verified": { "color": "green", "text": "Verified" } } },
                  { "type": "value", "options": { "contradicted": { "color": "red", "text": "Contradicted" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "created_at" },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": ["count"],
          "countRows": true,
          "fields": ""
        },
        "sortBy": [
          { "displayName": "created_at", "desc": true }
        ]
      },
      "pluginVersion": "11.0.0"
    },
