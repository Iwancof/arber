    {
      "id": 1,
      "type": "stat",
      "title": "Events Today",
      "description": "Total events ingested since midnight",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT count(*) FROM content.event_ledger WHERE created_at >= CURRENT_DATE",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
