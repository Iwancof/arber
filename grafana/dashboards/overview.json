          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["sum", "mean", "max"]
        }
      },
      "pluginVersion": "11.0.0"
