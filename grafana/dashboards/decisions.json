    {
      "id": 5,
      "type": "table",
      "title": "Recent Decisions",
      "description": "Latest 30 decisions joined with forecast and instrument data",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  d.action,\n  d.score,\n  d.decision_status,\n  d.execution_mode,\n  d.policy_version,\n  f.model_family,\n  f.confidence,\n  i.symbol,\n  d.decided_at\nFROM forecasting.decision_ledger d\nJOIN forecasting.forecast_ledger f ON f.forecast_id = d.forecast_id\nLEFT JOIN core.instrument i ON i.instrument_id = f.instrument_id\nORDER BY d.decided_at DESC\nLIMIT 30",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "action" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "long_candidate": { "color": "green", "text": "Long Candidate" } } },
                  { "type": "value", "options": { "short_candidate": { "color": "red", "text": "Short Candidate" } } },
                  { "type": "value", "options": { "no_trade": { "color": "blue", "text": "No Trade" } } },
                  { "type": "value", "options": { "hedge": { "color": "purple", "text": "Hedge" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "score" },
            "properties": [
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 0.3 },
                    { "color": "yellow", "value": 0.5 },
                    { "color": "green", "value": 0.7 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "decision_status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "waiting_manual": { "color": "yellow", "text": "Waiting Manual" } } },
                  { "type": "value", "options": { "approved": { "color": "green", "text": "Approved" } } },
                  { "type": "value", "options": { "rejected": { "color": "red", "text": "Rejected" } } },
                  { "type": "value", "options": { "auto_approved": { "color": "dark-green", "text": "Auto Approved" } } },
                  { "type": "value", "options": { "expired": { "color": "semi-dark-orange", "text": "Expired" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "execution_mode" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "replay": { "color": "blue", "text": "Replay" } } },
                  { "type": "value", "options": { "shadow": { "color": "purple", "text": "Shadow" } } },
                  { "type": "value", "options": { "paper": { "color": "yellow", "text": "Paper" } } },
                  { "type": "value", "options": { "micro_live": { "color": "orange", "text": "Micro Live" } } },
                  { "type": "value", "options": { "live": { "color": "red", "text": "Live" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "confidence" },
            "properties": [
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "gradient"
                }
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 1
              },
              {
