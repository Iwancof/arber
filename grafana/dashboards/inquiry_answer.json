      "type": "table",
      "title": "Related Forecasts",
      "description": "Recent forecasts for context when answering questions",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 19 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
