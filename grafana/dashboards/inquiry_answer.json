      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  i.symbol,\n  f.model_family as \"Model\",\n  f.confidence,\n  CASE\n    WHEN f.forecast_json->>'direction_hint' IS NOT NULL\n    THEN f.forecast_json->>'direction_hint'\n    WHEN f.forecast_json->>'direction' IS NOT NULL\n    THEN f.forecast_json->>'direction'\n    ELSE 'unknown'\n  END as \"Direction\",\n  f.forecasted_at\nFROM forecasting.forecast_ledger f\nLEFT JOIN core.instrument i ON i.instrument_id = f.instrument_id\nORDER BY f.forecasted_at DESC\nLIMIT 10",
          "format": "table"
        }
