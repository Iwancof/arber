      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  ic.primary_symbol as \"Symbol\",\n  it.question_title as \"Question\",\n  ir.response_channel as \"Channel\",\n  ir.response_status as \"Response Status\",\n  ir.schema_valid as \"Valid\",\n  substring(ir.raw_response from 1 for 200) as \"Response Preview\",\n  ires.resolution_status as \"Resolution\",\n  ires.effective_weight as \"Weight\",\n  ir.submitted_at as \"Submitted\"\nFROM human_ops.inquiry_response ir\nJOIN human_ops.inquiry_task it ON it.inquiry_task_id = ir.inquiry_task_id\nJOIN human_ops.inquiry_case ic ON ic.inquiry_case_id = it.inquiry_case_id\nLEFT JOIN human_ops.inquiry_resolution ires ON ires.inquiry_response_id = ir.inquiry_response_id\nORDER BY ir.submitted_at DESC\nLIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
