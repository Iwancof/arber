      "title": "Related Events",
      "description": "Recent events from the event ledger for context",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 19 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  e.event_type,\n  e.direction_hint,\n  e.materiality,\n  i.symbol,\n  rd.headline,\n  e.created_at\nFROM content.event_ledger e\nLEFT JOIN core.instrument i ON i.instrument_id = e.issuer_instrument_id\nLEFT JOIN content.raw_document rd ON rd.raw_document_id = e.raw_document_id\nORDER BY e.created_at DESC\nLIMIT 10",
          "format": "table"
        }
