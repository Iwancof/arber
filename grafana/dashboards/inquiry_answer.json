    {
      "id": 4,
      "type": "table",
      "title": "Questions Needing Answers",
      "description": "Main operator working table -- claim tasks and submit responses from here",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "P51983C8ED1C8EA5A"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "P51983C8ED1C8EA5A"
          },
          "rawSql": "SELECT\n  it.inquiry_task_id as \"Task ID\",\n  ic.primary_symbol as \"Symbol\",\n  ic.inquiry_kind as \"Kind\",\n  ic.urgency_class as \"Urgency\",\n  it.question_title as \"Question\",\n  it.question_text as \"Details\",\n  it.task_status as \"Status\",\n  it.sla_class as \"SLA\",\n  it.deadline_at as \"Deadline\",\n  it.priority_score as \"Priority\",\n  CASE\n    WHEN it.deadline_at < now() THEN 'OVERDUE'\n    WHEN it.deadline_at < now() + interval '30 minutes' THEN 'DUE SOON'\n    ELSE 'OK'\n  END as \"Time Status\",\n  ic.title as \"Case Title\"\nFROM human_ops.inquiry_task it\nJOIN human_ops.inquiry_case ic ON ic.inquiry_case_id = it.inquiry_case_id\nWHERE it.task_status IN ('draft','visible','claimed','awaiting_response','submitted')\nORDER BY\n  CASE ic.urgency_class WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'normal' THEN 3 ELSE 4 END,\n  it.priority_score DESC,\n  it.deadline_at ASC",
          "format": "table"
        }
      ],
