{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PluginManifest",
  "type": "object",
  "required": [
    "plugin_code",
    "plugin_type",
    "plugin_version",
    "plugin_api_version",
    "capabilities"
  ],
  "properties": {
    "plugin_code": {
      "type": "string"
    },
    "plugin_type": {
      "type": "string"
    },
    "plugin_version": {
      "type": "string"
    },
    "plugin_api_version": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supported_markets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}