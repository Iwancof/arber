{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptResponse",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "task_id",
    "model_name",
    "submitted_at",
    "parsed_json"
  ],
  "properties": {
    "schema_name": {
      "const": "prompt_response"
    },
    "schema_version": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "raw_response": {
      "type": "string"
    },
    "parsed_json": {
      "type": "object"
    },
    "schema_valid": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}